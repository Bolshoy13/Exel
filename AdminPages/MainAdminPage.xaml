<Page x:Class="Velic.Pages.AdminPages.MainAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Velic.Pages.AdminPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainAdminPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="29*"/>
            <RowDefinition Height="8*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#6A5ACD">
            <DockPanel Background="#6A5ACD" VerticalAlignment="Top">
                <Image Source="/Resources/icon.ico" Height="75" HorizontalAlignment="Left"/>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" FontSize="26" FontWeight="Bold">
                    ООО «ВелосипедДрайв»
                </TextBlock>
            </DockPanel>
        </Border>
        
        <Border Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button FontSize="24" FontFamily="Arial" Background="#4B0082" Foreground="White" Width="120" Click="TovarPageButton">
                    Товары
                </Button>
                
                <Button FontSize="24" FontFamily="Arial" Background="#4B0082" Foreground="White" Width="120" Margin="0 20 0 0" Click="ZakazPageButton">
                    Заказы
                </Button>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2" Background="#6A5ACD">
            
        </Border>

    </Grid>
</Page>
