<Page x:Class="Velic.Pages.AdminPages.RedTovarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Velic.Pages.AdminPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RedTovarPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="245*"/>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="52*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#6A5ACD" VerticalAlignment="Top" Grid.ColumnSpan="2" Grid.Row="0">
            <Image Source="/Resources/icon.ico" Height="55" HorizontalAlignment="Left"/>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" FontSize="26" FontWeight="Bold">
            ООО «ВелосипедДрайв»
            </TextBlock>
        </DockPanel>

        <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Артикул
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="ArtTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Название товара
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="NameTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Единица измерения
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="EdIzmerTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Цена
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="CenaTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Поставщик
            </TextBlock>
            <ComboBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="PostavshicCombo" Foreground="Black">

            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Производитель
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="ProizvodTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Категория товара
            </TextBlock>
            <ComboBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="KatCombo" Foreground="Black">

            </ComboBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Скидка
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="ScidkaTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Количество на складе
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="KolVoTxt">

            </TextBox>
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Фото
            </TextBlock>
            <TextBox Width="200" FontFamily="Arial" Margin="0 0 0 10" x:Name="PhotoPathTxt">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.ColumnSpan="2" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Margin="0 0 0 5" HorizontalAlignment="Center" FontFamily="Arial" FontSize="16">
            Описание товара
            </TextBlock>
            <TextBox Width="500" FontFamily="Arial" Margin="0 0 0 10" Height="50" x:Name="DescTxt">

            </TextBox>
        </StackPanel>

        <StackPanel Grid.ColumnSpan="2" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button FontFamily="Arial" FontSize="16" Width="120" Foreground="White" Background="#4B0082" Margin="0 0 15 0" Click="AddNewTovarButton">
                Редактировать
            </Button>

            <Button FontFamily="Arial" FontSize="16" Width="100" Foreground="White" Background="#4B0082" Click="BackPageButton">
                Назад
            </Button>
        </StackPanel>
    </Grid>
</Page>
