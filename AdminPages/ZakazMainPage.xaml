<Page x:Class="Velic.Pages.AdminPages.ZakazMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Velic.Pages.AdminPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ZakazMainPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#6A5ACD">
            <UIElement.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </UIElement.RenderTransform>
            <DockPanel Background="#6A5ACD" VerticalAlignment="Top">
                <Image Source="/Resources/icon.ico" Height="55" HorizontalAlignment="Left"/>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" FontSize="26" FontWeight="Bold">
                ООО «ВелосипедДрайв»
                </TextBlock>
            </DockPanel>
        </Border>

        <ListView Grid.Row="1" Margin="10,10,10,10" x:Name="ZakazList">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="3" Padding="10" Margin="5" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2" Margin="5" Padding="10">
                                <StackPanel Margin="10 0 0 0" MaxWidth="1000">
                                    <TextBlock FontFamily="Arial" FontSize="16" TextWrapping="Wrap">
                                    <Run Text="Артикул заказа: "/>
                                    <Run Text="{Binding Articul}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Arial" FontSize="16" TextWrapping="Wrap">
                                    <Run Text="Статус заказа: "/>
                                    <Run Text="{Binding Zakaz_.StatusZakaz_.NameStatus}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Arial" FontSize="16" TextWrapping="Wrap">
                                    <Run Text="Адрес пункта выдачи: "/>
                                    <Run Text="{Binding Zakaz_.PunktVidachi_.IndexPunkta}"/>
                                    </TextBlock>
                                    <TextBlock FontFamily="Arial" FontSize="16" TextWrapping="Wrap">
                                    <Run Text="Дата заказа: "/>
                                    <Run Text="{Binding Zakaz_.DataZakaza}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2">
                                <Grid Width="150" Height="150">
                                    <TextBlock FontFamily="Arial" FontSize="16" TextWrapping="Wrap" Width="130">
                                    <Run Text="Дата доставки: "/>
                                    <Run Text="{Binding Zakaz_.DataPostavki}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Background="#6A5ACD">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="140" Click="AddZakazPageButton">
                    Добавить заказ
                </Button>
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="90" Click="DeletTovarButton">
                    Удалить
                </Button>
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="130" Click="RedTovarPageButton">
                    Редактировать
                </Button>
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="90" Click="BackPageButton">
                    Назад
                </Button>
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="100" Click="SortVozrastButton">
                    Возрастание
                </Button>
                <Button FontFamily="Arial" Foreground="White" Margin="0 0 10 0" Background="#4B0082" FontSize="16" Width="90" Click="SortUbivButton">
                    Убывание
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
