<Page x:Class="Velic.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Velic.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      Background="White">

    <Grid>
        <StackPanel>
            <DockPanel Background="#6A5ACD" VerticalAlignment="Top">
                <Image Source="/Resources/icon.ico" Height="100" HorizontalAlignment="Left"/>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" FontSize="26" FontWeight="Bold">
                    ООО «ВелосипедДрайв»
                </TextBlock>
            </DockPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 60 0 0">
                <TextBlock FontFamily="Arial" FontSize="30" FontWeight="Bold">
                    Добро пожаловать
                </TextBlock>

                <TextBlock FontFamily="Arial" FontSize="18" HorizontalAlignment="Center" Margin="0 30 0 0">
                    Логин
                </TextBlock>
                <TextBox x:Name="LoginTxt" FontFamily="Arial" Margin="0 5 0 0">

                </TextBox>

                <TextBlock FontFamily="Arial" FontSize="18" HorizontalAlignment="Center" Margin="0 10 0 0">
                    Пароль
                </TextBlock>
                <PasswordBox x:Name="PasswordTxt" FontFamily="Arial" Margin="0 5 0 0">

                </PasswordBox>

                <Button FontFamily="Arial" Foreground="White" Margin="0 20 0 0" Background="#4B0082" FontSize="20" HorizontalAlignment="Center" Width="150" Click="LoginClientButton">
                    Войти
                </Button>

                <Button FontFamily="Arial" Foreground="White" Margin="0 10 0 0" Background="#4B0082" FontSize="20" HorizontalAlignment="Center" Width="200" Click="LoginGostButton">
                    Войти как гость
                </Button>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>
